{
  "functions": {
    "api/chat.js": {
      "memory": 256,
      "maxDuration": 60
    },
    "api/notify.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/notify-coaches-push.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/cron/notify-morning.js": {
      "memory": 128,
      "maxDuration": 30
    },
    "api/cron/notify-evening.js": {
      "memory": 128,
      "maxDuration": 30
    },
    "api/cron/notify-coaches.js": {
      "memory": 128,
      "maxDuration": 30
    },
    "api/cron/notify-daily.js": {
      "memory": 128,
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/notify-morning",
      "schedule": "0 12 * * 1,5"
    },
    {
      "path": "/api/cron/notify-evening",
      "schedule": "0 1 * * 3,0"
    },
    {
      "path": "/api/cron/notify-coaches",
      "schedule": "30 11 * * 1-5"
    },
    {
      "path": "/api/cron/notify-daily",
      "schedule": "0 15 * * *"
    }
  ]
}